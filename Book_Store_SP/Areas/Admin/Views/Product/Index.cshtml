@{
    ViewData["Title"] = "Products";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-9">
        <h2 class="text-primary">Products</h2>
    </div>
    <div class="col-3">
        <a asp-area="Admin" asp-controller="Product" asp-action="Upsert"
               class="btn btn-info">
            <i class="fas fa-plus"></i>&nbsp;Add New Product
        </a>
    </div>
</div>

<div class="container rounded border p-2 m-2">
    <table id="tblData" class="table table-striped table-bordered table-active">
        <thead>
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>ISBN</th>
                <th>List Price</th>
                <th>Category</th>
                <th>Cover Type</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>
</div>

@section Scripts {
    <script src="~/js/product.js"></script>
}