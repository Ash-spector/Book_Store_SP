@{
    ViewData["Title"] = "Cover Type";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-9">
        <h2 class="text-primary">Cover Type</h2>
    </div>
    <div class="col-3">
        <a asp-area="Admin" asp-controller="CoverType" asp-action="Upsert"
               class="btn btn-info ">
            <i class="fas fa-plus"></i>&nbsp;Add New Cover Type
        </a>
    </div>
</div>

<div class="container rounded border p-2 m-2">
    <table id="tblData" class="table table-striped table-bordered table-active">
        <thead>
            <tr>
                <th>Name</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>
</div>

@section Scripts {
    <script src="~/js/covertype.js"></script>
}